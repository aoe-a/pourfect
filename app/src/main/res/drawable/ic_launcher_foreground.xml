<?xml version="1.0" encoding="utf-8"?>
<!-- Pourfect app icon — "Bold" Bloom Ring foreground.
     108x108 adaptive-icon canvas; mark scaled into the 72dp safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Scale the 0..100 design space into the centered 72dp safe zone -->
    <group
        android:scaleX="0.72"
        android:scaleY="0.72"
        android:translateX="18"
        android:translateY="18">

        <!-- Timer track: full ring, dark warm charcoal, thick -->
        <path
            android:pathData="M19,50 a31,31 0 1 0 62,0 a31,31 0 1 0 -62,0"
            android:strokeColor="#2C2822"
            android:strokeWidth="8"
            android:fillColor="#00000000" />

        <!-- Progress arc: ~66% sweep from top, clockwise, gold->amber->ember -->
        <path
            android:pathData="M50,19 A31,31 0 1 1 23.8,66.6"
            android:strokeWidth="8"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="20" android:startY="20"
                    android:endX="80" android:endY="80">
                    <item android:offset="0"    android:color="#FFDCA8" />
                    <item android:offset="0.55" android:color="#FFB74D" />
                    <item android:offset="1"    android:color="#FF8E3C" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- V60 cone body, top-lit amber gradient -->
        <path
            android:pathData="M35,38 L65,38 L52,63 Q50,65 48,63 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="50" android:startY="38"
                    android:endX="50" android:endY="64">
                    <item android:offset="0"    android:color="#FFDCA8" />
                    <item android:offset="0.45" android:color="#FFB74D" />
                    <item android:offset="1"    android:color="#C77E2B" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Ribbed lines converging to the tip -->
        <path android:pathData="M41,38 L50,64"  android:strokeColor="#C77E2B" android:strokeWidth="1" android:strokeAlpha="0.5" android:strokeLineCap="round" />
        <path android:pathData="M47,38 L50,64"  android:strokeColor="#C77E2B" android:strokeWidth="1" android:strokeAlpha="0.5" android:strokeLineCap="round" />
        <path android:pathData="M53,38 L50,64"  android:strokeColor="#C77E2B" android:strokeWidth="1" android:strokeAlpha="0.5" android:strokeLineCap="round" />
        <path android:pathData="M59,38 L50,64"  android:strokeColor="#C77E2B" android:strokeWidth="1" android:strokeAlpha="0.5" android:strokeLineCap="round" />

        <!-- Bright gold rim -->
        <path android:pathData="M35,38 L65,38" android:strokeColor="#FFDCA8" android:strokeWidth="2.6" android:strokeLineCap="round" />
    </group>
</vector>
